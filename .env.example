# ── Admin ──
# Your Aptos wallet address — ONLY this wallet can access /admin
NEXT_PUBLIC_ADMIN_WALLET=your_aptos_wallet_address_here

# ── Upstash Redis (get from upstash.com — free tier) ──
UPSTASH_REDIS_REST_URL=your_upstash_redis_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# ── Shelby Protocol ──
SHELBY_API_KEY=your_shelby_api_key_here
SHELBY_API_URL=https://api.shelby.xyz
NEXT_PUBLIC_SHELBY_NETWORK=testnet

# ── GenLayer ──
GENLAYER_RPC_URL=https://studio.genlayer.com/api
GENLAYER_CONTRACT_ADDRESS=your_deployed_contract_address_here
NEXT_PUBLIC_GENLAYER_NETWORK=testnet

# ── Aptos ──
NEXT_PUBLIC_APTOS_NETWORK=testnet
NEXT_PUBLIC_APTOS_NODE_URL=https://fullnode.testnet.aptoslabs.com/v1

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
JWT_SECRET=change_this_to_a_random_32_char_string

# ── Revenue split (%) ──
OWNER_SHARE_PCT=70
PLATFORM_FEE_PCT=20
GENLAYER_FEE_PCT=10

# ── Access window ──
NEXT_PUBLIC_ACCESS_FEE_USDC=2
NEXT_PUBLIC_ACCESS_DAYS=7
